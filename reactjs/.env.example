# WalletConnect Cloud project ID — required for multi-wallet support
# Get one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Testnet RPC URLs (optional — defaults to public RPC endpoints)
VITE_RPC_URL_SEPOLIA=
VITE_RPC_URL_POLYGON_AMOY=

# Deployed contract address (testnet only — NEVER mainnet)
VITE_CONTRACT_ADDRESS=

# Supabase (Phase 5+ — leave blank for now)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
