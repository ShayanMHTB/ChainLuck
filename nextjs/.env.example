# =============================================================================
# ChainLuck Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# =============================================================================
# 🌐 NETWORK & BLOCKCHAIN CONFIGURATION
# =============================================================================

# WalletConnect Project ID (REQUIRED)
# Get from: https://cloud.walletconnect.com/
# Used for mobile wallet connections and QR code scanning
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Infura API Key (RECOMMENDED)
# Get from: https://infura.io/
# Provides reliable RPC endpoints for Ethereum networks
NEXT_PUBLIC_INFURA_KEY=your_infura_api_key_here

# =============================================================================
# 📄 SMART CONTRACT ADDRESSES (Sepolia Testnet)
# =============================================================================

# ChainLuck Lottery Contract (Your deployed contract)
NEXT_PUBLIC_CHAINLUCK_ADDRESS_SEPOLIA=0x01A42965b8c813b8AfB3c6e455Ec7cD3C342F00B

# Mock USDC Contract (Your test USDC token)
NEXT_PUBLIC_USDC_ADDRESS_SEPOLIA=0x7f926FcD24c451Fa1a7b9c5887033DaE9ce7E672

# =============================================================================
# 🏗️ APPLICATION CONFIGURATION
# =============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Site URL (used for metadata and social sharing)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# App Version (automatically set during build)
NEXT_PUBLIC_APP_VERSION=1.0.0

# =============================================================================
# 🎯 FEATURE FLAGS & TOGGLES
# =============================================================================

# Enable debug mode (shows debug panels and extra logging)
NEXT_PUBLIC_DEBUG_MODE=true

# Enable analytics (Google Analytics, Mixpanel, etc.)
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Enable testnet faucet functionality
NEXT_PUBLIC_TESTNET_FAUCET_ENABLED=true

# =============================================================================
# 📊 ANALYTICS & MONITORING (Optional)
# =============================================================================

# Google Analytics Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here

# =============================================================================
# 🚀 DEPLOYMENT & BUILD CONFIGURATION
# =============================================================================

# Build optimization settings
NEXT_PUBLIC_BUILD_STANDALONE=true

# CDN URL for static assets (leave empty for default)
NEXT_PUBLIC_CDN_URL=https://cdn.chainluck.com

# =============================================================================
# 🔐 SECURITY & COMPLIANCE
# =============================================================================

# Content Security Policy (CSP) enforcement
NEXT_PUBLIC_CSP_ENABLED=false

# Enable strict transport security headers
NEXT_PUBLIC_HSTS_ENABLED=true

# =============================================================================
# 🌍 INTERNATIONALIZATION
# =============================================================================

# Default language (en, fa, etc.)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Supported locales (comma-separated)
NEXT_PUBLIC_SUPPORTED_LOCALES=en,fa

# =============================================================================
# 💳 PAYMENT & WALLET CONFIGURATION
# =============================================================================

# Default chain ID for wallet connections
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111

# Supported chain IDs (comma-separated)
NEXT_PUBLIC_SUPPORTED_CHAIN_IDS=11155111,80001,137

# Enable WalletConnect v2
NEXT_PUBLIC_WALLETCONNECT_V2=true

# =============================================================================
# 🎮 GAME CONFIGURATION
# =============================================================================

# Enable win animations
NEXT_PUBLIC_WIN_ANIMATIONS=true

# Animation duration (milliseconds)
NEXT_PUBLIC_ANIMATION_DURATION=3000

# Enable sound effects
NEXT_PUBLIC_SOUND_EFFECTS=false

# =============================================================================
# 📱 UI/UX CONFIGURATION
# =============================================================================

# Default theme (light, dark, system)
NEXT_PUBLIC_DEFAULT_THEME=system

# Enable dark mode toggle
NEXT_PUBLIC_DARK_MODE_ENABLED=true

# Enable RTL support
NEXT_PUBLIC_RTL_SUPPORT=true

# =============================================================================
# 🔧 DEVELOPMENT TOOLS
# =============================================================================

# Enable React DevTools in production
NEXT_PUBLIC_REACT_DEVTOOLS=false

# Enable Redux DevTools
NEXT_PUBLIC_REDUX_DEVTOOLS=false

# Show performance metrics
NEXT_PUBLIC_PERFORMANCE_METRICS=false

# =============================================================================
# 📞 SUPPORT & CONTACT
# =============================================================================

# Support email address
NEXT_PUBLIC_SUPPORT_EMAIL=support@chainluck.com

# Twitter handle (without @)
NEXT_PUBLIC_TWITTER_HANDLE=ChainLuckLottery

# Discord invite link
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/chainluck

# =============================================================================
# 🎯 MARKETING & SEO
# =============================================================================

# Google Tag Manager ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=123456789

# Twitter tracking ID
NEXT_PUBLIC_TWITTER_PIXEL_ID=o1234

# =============================================================================
# 🛡️ PRODUCTION OVERRIDES
# =============================================================================
# These should be set differently in production environments

# Production site URL
# NEXT_PUBLIC_SITE_URL=https://chainluck.com

# Production environment
# NODE_ENV=production

# Disable debug mode in production
# NEXT_PUBLIC_DEBUG_MODE=false

# Enable analytics in production
# NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Production contract addresses (when deployed to mainnet)
# NEXT_PUBLIC_CHAINLUCK_ADDRESS_POLYGON=0x...
# NEXT_PUBLIC_USDC_ADDRESS_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
