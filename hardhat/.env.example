# hardhat/.env.example

# ═════════════════════════════════════════════════════════════
#                      🔐 WALLET CONFIGURATION                 
# ═════════════════════════════════════════════════════════════
PRIVATE_KEY=your_64_character_private_key_here_without_0x_prefix
MNEMONIC=your twelve word mnemonic phrase here

# ═════════════════════════════════════════════════════════════
#                      🌐 RPC ENDPOINTS                         
# ═════════════════════════════════════════════════════════════
# Infura Project ID (used for multiple networks)
INFURA_PROJECT_ID=your_infura_project_id_here

# TESTNETS
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
MUMBAI_RPC_URL=https://polygon-mumbai.infura.io/v3/YOUR_INFURA_PROJECT_ID
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# MAINNETS
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# ═════════════════════════════════════════════════════════════
#                     🔍 BLOCK EXPLORER API KEYS               
# ═════════════════════════════════════════════════════════════
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here
ARBITRUMSCAN_API_KEY=your_arbitrumscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here

# ═════════════════════════════════════════════════════════════
#                     🎲 CHAINLINK VRF SETTINGS (OPTIONAL)     
# ═════════════════════════════════════════════════════════════
# Note: Multi-tier contract uses enhanced pseudo-random by default
# VRF can be added later for premium grand prizes

VRF_SUBSCRIPTION_ID=1
VRF_COORDINATOR_SEPOLIA=0x8103B0A8A00be2DDC778e6e7eaa21791Cd364625
VRF_KEY_HASH_SEPOLIA=0x474e34a077df58807dbe9c96d3c009b23b3c6d0cce433e59bbf5b34f823bc56c
VRF_CALLBACK_GAS_LIMIT=100000

# ═════════════════════════════════════════════════════════════
#                    📋 NETWORK USDC ADDRESSES                 
# ═════════════════════════════════════════════════════════════
# TESTNETS (Official testnet USDC contracts)
SEPOLIA_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
MUMBAI_USDC=0x2058A9D7613eEE744279e3856Ef0eAda5FCbaA7e
BSC_TESTNET_USDC=0x337610d27c682E347C9cD60BD4b3b107C9d34dDd
ARBITRUM_SEPOLIA_USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# MAINNETS (Official USDC contracts)
POLYGON_USDC=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
BSC_USDC=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
ARBITRUM_USDC=0xA0b86a33E6417b4a000000000000000000000000
BASE_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ═════════════════════════════════════════════════════════════
#                    🎰 DEPLOYED CONTRACT ADDRESSES           
# ═════════════════════════════════════════════════════════════
# Multi-Tier ChainLuck contracts (filled after deployment)
CHAINLUCK_SEPOLIA=
CHAINLUCK_MUMBAI=
CHAINLUCK_BSC_TESTNET=
CHAINLUCK_ARBITRUM_SEPOLIA=

CHAINLUCK_POLYGON=
CHAINLUCK_BSC=
CHAINLUCK_ARBITRUM=
CHAINLUCK_BASE=

# Legacy support
CHAINLUCK_ADDRESS=
CHAINLUCK_PROXY_ADDRESS=

# ═════════════════════════════════════════════════════════════
#                       🧪 TESTING CONFIGURATION               
# ═════════════════════════════════════════════════════════════
# Test wallet addresses (auto-generated by scripts)
TEST_WALLET_1=
TEST_WALLET_2=
TEST_WALLET_3=
TEST_WALLET_4=
TEST_WALLET_5=

# Test funding amounts
TEST_USDC_PER_WALLET=10000  # $10,000 USDC per test wallet
TEST_ETH_PER_WALLET=0.1     # 0.1 ETH per test wallet for gas
TEST_WALLET_COUNT=5         # Number of test wallets to generate

# ═════════════════════════════════════════════════════════════
#                    🏦 MULTI-TIER POOL FUNDING                
# ═════════════════════════════════════════════════════════════
# Initial funding amounts per tier (in USDC - 6 decimals)

# BASIC TIER ($1 tickets)
INITIAL_BASIC_INSTANT_POOL=2000000000      # $2,000
INITIAL_BASIC_GRAND_PRIZE_POOL=5000000000  # $5,000

# STANDARD TIER ($2 tickets)  
INITIAL_STANDARD_INSTANT_POOL=5000000000      # $5,000
INITIAL_STANDARD_GRAND_PRIZE_POOL=10000000000 # $10,000

# PREMIUM TIER ($5 tickets)
INITIAL_PREMIUM_INSTANT_POOL=10000000000     # $10,000
INITIAL_PREMIUM_GRAND_PRIZE_POOL=25000000000 # $25,000

# Legacy pool funding (for backward compatibility)
INITIAL_INSTANT_POOL=10000000000   # $10,000
INITIAL_GRAND_PRIZE_POOL=20000000000  # $20,000

# ═════════════════════════════════════════════════════════════
#                    🎁 SPECIAL LOTTERY CONFIGURATION          
# ═════════════════════════════════════════════════════════════
# Prize pools for special lotteries (in USDC - 6 decimals)

DAILY_STREAK_LOTTERY_POOL=45000000        # $45 daily
WEEKLY_REFERRAL_LOTTERY_POOL=250000000    # $250 weekly
MONTHLY_TIER_LOTTERY_POOL=1100000000      # $1,100 monthly
QUARTERLY_CROSS_LOTTERY_POOL=2000000000   # $2,000 quarterly
ANNUAL_WHALE_LOTTERY_POOL=5000000000      # $5,000 yearly

# ═════════════════════════════════════════════════════════════
#                     ⚙️  DEPLOYMENT SETTINGS                  
# ═════════════════════════════════════════════════════════════
# Gas settings (network-specific)
GAS_PRICE_MULTIPLIER=1.2
GAS_LIMIT_MULTIPLIER=1.2

# Network-specific gas prices (gwei)
POLYGON_GAS_PRICE=30
BSC_GAS_PRICE=5
ARBITRUM_GAS_PRICE=0.1
SEPOLIA_GAS_PRICE=auto

# Transaction confirmations required
POLYGON_CONFIRMATIONS=2
BSC_CONFIRMATIONS=3
ARBITRUM_CONFIRMATIONS=1
SEPOLIA_CONFIRMATIONS=1

# ═════════════════════════════════════════════════════════════
#                     🔧 DEVELOPMENT FLAGS                     
# ═════════════════════════════════════════════════════════════
NODE_ENV=development
NETWORK=sepolia  # Primary network for development
AUTO_VERIFY=true
SAVE_DEPLOYMENT_LOGS=true

# Multi-chain deployment flags
DEPLOY_TO_TESTNETS=true
DEPLOY_TO_MAINNETS=false
SKIP_CONFIRMATION=false

# Debugging and monitoring
DEBUG_MODE=false
VERBOSE_LOGGING=false
REPORT_GAS=true

# ═════════════════════════════════════════════════════════════
#                    🔒 SECURITY SETTINGS                      
# ═════════════════════════════════════════════════════════════
# Minimum balance requirements (in ETH)
MIN_DEPLOYER_BALANCE_TESTNET=0.1
MIN_DEPLOYER_BALANCE_MAINNET=1.0

# Maximum gas price willing to pay (gwei)
MAX_GAS_PRICE_TESTNET=100
MAX_GAS_PRICE_MAINNET=50

# Require manual confirmation for mainnet deployments
MAINNET_CONFIRMATION_REQUIRED=true

# Enable automated pool management (use with caution)
AUTO_POOL_MANAGEMENT=false

# ═════════════════════════════════════════════════════════════
#                   📊 ANALYTICS & MONITORING                  
# ═════════════════════════════════════════════════════════════
# CoinMarketCap API for USD gas cost calculation
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Enable transaction timeout (milliseconds)
TRANSACTION_TIMEOUT=300000

# Batch processing settings
BATCH_SIZE=3
NETWORK_DELAY=2000
MAX_RETRIES=3

# ═════════════════════════════════════════════════════════════
#                     🚀 PRODUCTION OVERRIDES                  
# ═════════════════════════════════════════════════════════════
# Set these when deploying to production

# Production deployment flag
PRODUCTION_DEPLOYMENT=false

# Override default settings for production
PRODUCTION_MIN_POOL_BALANCE=50000000000  # $50,000 minimum
PRODUCTION_MAX_SINGLE_WITHDRAWAL=10000000000  # $10,000 max withdrawal

# Emergency settings
EMERGENCY_PAUSE_ENABLED=false
EMERGENCY_CONTACT=your_emergency_contact_address

# ═════════════════════════════════════════════════════════════
#                    💡 CONFIGURATION EXAMPLES                 
# ═════════════════════════════════════════════════════════════
# Replace with your actual values:

# Example private key (64 hex characters):
# PRIVATE_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Example Infura setup:
# INFURA_PROJECT_ID=abc123def456ghi789
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/abc123def456ghi789

# Example API keys:
# ETHERSCAN_API_KEY=ABC123DEF456GHI789
# POLYGONSCAN_API_KEY=XYZ789ABC123DEF456

# Multi-chain deployment settings
TARGET_TESTNETS=sepolia,mumbai,bscTestnet
TARGET_MAINNETS=polygon,bsc,arbitrumOne

# =============================================================================
# SECURITY & MONITORING
# =============================================================================

# Minimum balance threshold before deployment warning (in ETH)
MIN_DEPLOYER_BALANCE=0.1

# Enable deployment confirmation prompts for mainnet
MAINNET_CONFIRMATION_REQUIRED=true

# Maximum gas price willing to pay (in gwei)
MAX_GAS_PRICE_GWEI=50

# Transaction timeout (in milliseconds)
TRANSACTION_TIMEOUT=300000

# =============================================================================
# FRONTEND INTEGRATION
# =============================================================================

# Supabase configuration (for frontend sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Analytics and monitoring
ANALYTICS_ENABLED=true
ERROR_REPORTING_ENABLED=true

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Enable verbose logging
DEBUG_MODE=false

# Skip confirmation prompts for automated deployment
AUTO_CONFIRM=false

# Test with forked networks
FORK_ENABLED=false
FORK_BLOCK_NUMBER=latest

# =============================================================================
# PRODUCTION DEPLOYMENT FLAGS
# =============================================================================

# Set to true when deploying to production
PRODUCTION_DEPLOYMENT=false

# Require manual approval for large transactions
REQUIRE_MANUAL_APPROVAL=true

# Enable automated pool management
AUTO_POOL_MANAGEMENT=false

# =============================================================================
# EXAMPLE VALUES (REPLACE WITH YOUR OWN)
# =============================================================================

# Example Infura configuration:
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/abc123def456
# POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/abc123def456

# Example API keys:
# ETHERSCAN_API_KEY=ABC123DEF456GHI789JKL012
# POLYGONSCAN_API_KEY=DEF456GHI789JKL012MNO345

# Example private key format (64 characters, no 0x):
# PRIVATE_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# =============================================================================
# NETWORK-SPECIFIC OVERRIDES
# =============================================================================

# Override gas settings per network (optional)
POLYGON_GAS_PRICE=30
BSC_GAS_PRICE=5
ARBITRUM_GAS_PRICE=0.1

# Override confirmation requirements per network
POLYGON_CONFIRMATIONS=2
BSC_CONFIRMATIONS=3
ARBITRUM_CONFIRMATIONS=1

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Backup deployment info to external storage
BACKUP_ENABLED=false
BACKUP_STORAGE_URL=

# Recovery mode (use existing deployment if available)
RECOVERY_MODE=false

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Batch size for multi-network operations
BATCH_SIZE=3

# Delay between network operations (milliseconds)
NETWORK_DELAY=2000

# Maximum retries for failed operations
MAX_RETRIES=3

# Retry delay multiplier
RETRY_DELAY_MULTIPLIER=1.5
