# ═════════════════════════════════════════════════════════════
#                       🧪 TESTING CONFIGURATION               
# ═════════════════════════════════════════════════════════════
# Test wallet addresses (auto-generated)
TEST_WALLET_1=
TEST_WALLET_2=
TEST_WALLET_3=
TEST_WALLET_4=
TEST_WALLET_5=

# Test private keys (auto-generated)
TEST_PRIVATE_KEY_1=
TEST_PRIVATE_KEY_2=
TEST_PRIVATE_KEY_3=
TEST_PRIVATE_KEY_4=
TEST_PRIVATE_KEY_5=

# ═════════════════════════════════════════════════════════════
#                     ⚙️  DEPLOYMENT SETTINGS                  
# ═════════════════════════════════════════════════════════════
# Gas settings
GAS_PRICE_GWEI=30
GAS_LIMIT=8000000

# Deployment flags
DEPLOY_MOCKS=true
AUTO_VERIFY=true
SKIP_CONFIRMATION=false

# Initial funding amounts (in token decimals)
INITIAL_PRIZE_POOL_USD=1000
INITIAL_REFERRAL_POOL_USD=500

# ═════════════════════════════════════════════════════════════
#                     🔧 DEVELOPMENT FLAGS                    
# ═════════════════════════════════════════════════════════════
NODE_ENV=development
DEBUG_MODE=true
VERBOSE_LOGGING=true
SAVE_DEPLOYMENT_LOGS=true
