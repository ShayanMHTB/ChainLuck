# File: hardhat/.env

# ═════════════════════════════════════════════════════════════
#                      🔐 WALLET CONFIGURATION                 
# ═════════════════════════════════════════════════════════════
PRIVATE_KEY=your_64_character_private_key_here_without_0x_prefix
MNEMONIC=your twelve word mnemonic phrase here

# ═════════════════════════════════════════════════════════════
#                      🌐 NETWORK RPC ENDPOINTS                 
# ═════════════════════════════════════════════════════════════
# Polygon Mainnet
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_URL_BACKUP=https://rpc-mainnet.matic.quiknode.pro

# Polygon Testnet (Mumbai)
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
MUMBAI_RPC_URL_BACKUP=https://matic-mumbai.chainstacklabs.com

# BSC Mainnet
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_RPC_URL_BACKUP=https://bsc-dataseed2.binance.org

# BSC Testnet
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Ethereum Mainnet (if needed)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_api_key_here

# ═════════════════════════════════════════════════════════════
#                     🔍 BLOCK EXPLORER API KEYS               
# ═════════════════════════════════════════════════════════════
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ═════════════════════════════════════════════════════════════
#                     🎲 CHAINLINK VRF SETTINGS                
# ═════════════════════════════════════════════════════════════
VRF_SUBSCRIPTION_ID=1
VRF_COORDINATOR_POLYGON=0x7a1BaC17Ccc5b313516C5E16fb24f7659aA5ebed
VRF_KEY_HASH_POLYGON=0x4b09e658ed251bcafeebbc69400383d49f344ace09b9576fe248bb02c003fe9f

