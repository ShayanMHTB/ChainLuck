{
  "name": "chainluck-contracts",
  "version": "1.0.0",
  "description": "ChainLuck Smart Contracts for Sepolia Testnet",
  "main": "index.js",
  "scripts": {
    "clean": "npx hardhat clean",
    "compile": "npx hardhat compile",
    "console": "npx hardhat console --network sepolia",
    "deploy": "npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:all": "npm run compile && npm run deploy && npm run verify && npm run fund",
    "verify": "npx hardhat run scripts/verify.ts --network sepolia",
    "fund": "npx hardhat run scripts/fund-pools.ts --network sepolia",
    "fund:wallets": "npx hardhat run scripts/fund-test-wallets.ts --network sepolia",
    "setup": "npx hardhat run scripts/setup-wallets.ts --network sepolia",
    "setup:dev": "npm run deploy:all && npm run setup && npm run fund:wallets",
    "setup:complete": "npm run setup && npm run fund:wallets",
    "test": "npx hardhat test",
    "test:gas": "REPORT_GAS=true npx hardhat test",
    "test:game": "npx hardhat run scripts/test-gameplay.ts --network sepolia",
    "node": "npx hardhat node",
    "flatten": "npx hardhat flatten contracts/ChainLuck.sol > flattened.sol",
    "size": "npx hardhat size-contracts"
  },
  "keywords": [
    "blockchain",
    "lottery",
    "ethereum",
    "sepolia",
    "chainlink"
  ],
  "author": "ChainLuck Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.0.0",
    "hardhat": "^2.19.0",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@chainlink/contracts": "^0.8.0",
    "@openzeppelin/contracts": "^5.3.0"
  }
}
