{
  "name": "chainluck-multi-tier-contracts",
  "version": "2.0.0",
  "description": "ChainLuck Multi-Tier Smart Contracts for Multiple Networks",
  "main": "index.js",
  "scripts": {
    "clean": "npx hardhat clean",
    "compile": "npx hardhat compile",
    "size": "npx hardhat size-contracts",
    "flatten": "npx hardhat flatten contracts/ChainLuck.sol > flattened.sol",
    "coverage": "npx hardhat coverage",
    "console": "npx hardhat console --network sepolia",
    "console:polygon": "npx hardhat console --network polygon",
    "console:bsc": "npx hardhat console --network bsc",
    "test": "npx hardhat test",
    "test:gas": "REPORT_GAS=true npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "test:multi-tier": "npx hardhat test test/MultiTier.test.ts",
    "deploy": "npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network hardhat",
    "deploy:testnets": "npm run deploy:sepolia && npm run deploy:mumbai && npm run deploy:bsc-testnet",
    "deploy:sepolia": "npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:mumbai": "npx hardhat run scripts/deploy.ts --network mumbai",
    "deploy:bsc-testnet": "npx hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:arbitrum-sepolia": "npx hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "deploy:mainnets": "npm run deploy:polygon && npm run deploy:bsc && npm run deploy:arbitrum",
    "deploy:polygon": "npx hardhat run scripts/deploy.ts --network polygon",
    "deploy:bsc": "npx hardhat run scripts/deploy.ts --network bsc",
    "deploy:arbitrum": "npx hardhat run scripts/deploy.ts --network arbitrumOne",
    "deploy:base": "npx hardhat run scripts/deploy.ts --network base",
    "deploy:all": "npm run compile && npm run deploy && npm run sync:config && npm run verify && npm run fund",
    "deploy:all-testnets": "npm run compile && npm run deploy:testnets && npm run sync:config:all && npm run verify:testnets",
    "deploy:all-mainnets": "npm run compile && npm run deploy:mainnets && npm run sync:config:all && npm run verify:mainnets",
    "verify": "npx hardhat run scripts/verify.ts --network sepolia",
    "verify:testnets": "npm run verify:sepolia && npm run verify:mumbai && npm run verify:bsc-testnet",
    "verify:sepolia": "npx hardhat run scripts/verify.ts --network sepolia",
    "verify:mumbai": "npx hardhat run scripts/verify.ts --network mumbai",
    "verify:bsc-testnet": "npx hardhat run scripts/verify.ts --network bscTestnet",
    "verify:arbitrum-sepolia": "npx hardhat run scripts/verify.ts --network arbitrumSepolia",
    "verify:mainnets": "npm run verify:polygon && npm run verify:bsc && npm run verify:arbitrum",
    "verify:polygon": "npx hardhat run scripts/verify.ts --network polygon",
    "verify:bsc": "npx hardhat run scripts/verify.ts --network bsc",
    "verify:arbitrum": "npx hardhat run scripts/verify.ts --network arbitrumOne",
    "verify:base": "npx hardhat run scripts/verify.ts --network base",
    "fund": "npx hardhat run scripts/fund-pools.ts --network sepolia",
    "fund:testnets": "npm run fund:sepolia && npm run fund:mumbai && npm run fund:bsc-testnet",
    "fund:sepolia": "npx hardhat run scripts/fund-pools.ts --network sepolia",
    "fund:mumbai": "npx hardhat run scripts/fund-pools.ts --network mumbai",
    "fund:bsc-testnet": "npx hardhat run scripts/fund-pools.ts --network bscTestnet",
    "fund:arbitrum-sepolia": "npx hardhat run scripts/fund-pools.ts --network arbitrumSepolia",
    "fund:mainnets": "npm run fund:polygon && npm run fund:bsc && npm run fund:arbitrum",
    "fund:polygon": "npx hardhat run scripts/fund-pools.ts --network polygon",
    "fund:bsc": "npx hardhat run scripts/fund-pools.ts --network bsc",
    "fund:arbitrum": "npx hardhat run scripts/fund-pools.ts --network arbitrumOne",
    "fund:base": "npx hardhat run scripts/fund-pools.ts --network base",
    "fund:wallets": "npx hardhat run scripts/fund-test-wallets.ts --network sepolia",
    "fund:wallets:testnets": "npm run fund:wallets:sepolia && npm run fund:wallets:mumbai",
    "fund:wallets:sepolia": "npx hardhat run scripts/fund-test-wallets.ts --network sepolia",
    "fund:wallets:mumbai": "npx hardhat run scripts/fund-test-wallets.ts --network mumbai",
    "fund:wallets:bsc-testnet": "npx hardhat run scripts/fund-test-wallets.ts --network bscTestnet",
    "setup": "npx hardhat run scripts/setup-wallets.ts --network sepolia",
    "setup:testnets": "npm run setup:sepolia && npm run setup:mumbai && npm run setup:bsc-testnet",
    "setup:sepolia": "npx hardhat run scripts/setup-wallets.ts --network sepolia",
    "setup:mumbai": "npx hardhat run scripts/setup-wallets.ts --network mumbai",
    "setup:bsc-testnet": "npx hardhat run scripts/setup-wallets.ts --network bscTestnet",
    "setup:arbitrum-sepolia": "npx hardhat run scripts/setup-wallets.ts --network arbitrumSepolia",
    "sync:config": "npx hardhat run scripts/sync-contract-config.ts --network sepolia",
    "sync:config:all": "npm run sync:config:testnets && npm run sync:config:mainnets",
    "sync:config:testnets": "npm run sync:config:sepolia && npm run sync:config:mumbai && npm run sync:config:bsc-testnet",
    "sync:config:sepolia": "npx hardhat run scripts/sync-contract-config.ts --network sepolia",
    "sync:config:mumbai": "npx hardhat run scripts/sync-contract-config.ts --network mumbai",
    "sync:config:bsc-testnet": "npx hardhat run scripts/sync-contract-config.ts --network bscTestnet",
    "sync:config:arbitrum-sepolia": "npx hardhat run scripts/sync-contract-config.ts --network arbitrumSepolia",
    "sync:config:mainnets": "npm run sync:config:polygon && npm run sync:config:bsc && npm run sync:config:arbitrum",
    "sync:config:polygon": "npx hardhat run scripts/sync-contract-config.ts --network polygon",
    "sync:config:bsc": "npx hardhat run scripts/sync-contract-config.ts --network bsc",
    "sync:config:arbitrum": "npx hardhat run scripts/sync-contract-config.ts --network arbitrumOne",
    "sync:config:base": "npx hardhat run scripts/sync-contract-config.ts --network base",
    "test:game": "npx hardhat run scripts/test-gameplay.ts --network sepolia",
    "test:game:testnets": "npm run test:game:sepolia && npm run test:game:mumbai",
    "test:game:sepolia": "npx hardhat run scripts/test-gameplay.ts --network sepolia",
    "test:game:mumbai": "npx hardhat run scripts/test-gameplay.ts --network mumbai",
    "test:game:bsc-testnet": "npx hardhat run scripts/test-gameplay.ts --network bscTestnet",
    "test:game:mainnets": "npm run test:game:polygon && npm run test:game:bsc",
    "test:game:polygon": "npx hardhat run scripts/test-gameplay.ts --network polygon",
    "test:game:bsc": "npx hardhat run scripts/test-gameplay.ts --network bsc",
    "test:game:arbitrum": "npx hardhat run scripts/test-gameplay.ts --network arbitrumOne",
    "setup:dev": "npm run deploy:all && npm run setup && npm run fund:wallets",
    "setup:dev:testnets": "npm run deploy:all-testnets && npm run setup:testnets && npm run fund:wallets:testnets",
    "setup:complete": "npm run setup && npm run fund:wallets",
    "node": "npx hardhat node",
    "node:fork": "npx hardhat node --fork https://polygon-rpc.com/",
    "node:fork:bsc": "npx hardhat node --fork https://bsc-dataseed1.binance.org/",
    "deploy:special-lotteries": "npx hardhat run scripts/deploy-special-lotteries.ts --network sepolia",
    "test:multi-tier-functions": "npx hardhat run scripts/test-multi-tier-functions.ts --network sepolia",
    "test:referral-system": "npx hardhat run scripts/test-referral-system.ts --network sepolia",
    "test:daily-checkins": "npx hardhat run scripts/test-daily-checkins.ts --network sepolia",
    "admin:withdraw-profits": "npx hardhat run scripts/admin/withdraw-profits.ts --network sepolia",
    "admin:manage-lotteries": "npx hardhat run scripts/admin/manage-special-lotteries.ts --network sepolia",
    "admin:emergency-withdraw": "npx hardhat run scripts/admin/emergency-withdraw.ts --network sepolia",
    "analytics:generate-report": "npx hardhat run scripts/analytics/generate-report.ts --network sepolia",
    "analytics:user-stats": "npx hardhat run scripts/analytics/user-analytics.ts --network sepolia",
    "analytics:tier-performance": "npx hardhat run scripts/analytics/tier-analytics.ts --network sepolia"
  },
  "keywords": [
    "blockchain",
    "lottery",
    "ethereum",
    "polygon",
    "bsc",
    "arbitrum",
    "multi-tier",
    "defi",
    "gaming"
  ],
  "author": "ChainLuck Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.0.0",
    "hardhat": "^2.19.0",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.9",
    "hardhat-abi-exporter": "^2.10.1",
    "solidity-coverage": "^0.8.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@chainlink/contracts": "^0.8.0",
    "@openzeppelin/contracts": "^5.3.0"
  }
}
